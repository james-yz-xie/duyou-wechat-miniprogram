/**app.wxss**/
@import './styles/common.wxss';

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 16px;
  line-height: 1.6;
  color: #333;
}

/* 主色调 */
.primary-color {
  color: #4A90D9;
}

.primary-bg {
  background-color: #4A90D9;
}

/* 成功色 */
.success-color {
  color: #52c41a;
}

.success-bg {
  background-color: #52c41a;
}

/* 警告色 */
.warning-color {
  color: #faad14;
}

/* 危险色 */
.danger-color {
  color: #ff4d4f;
}

/* 通用容器 */
.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn-primary {
  background-color: #4A90D9;
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 32rpx;
}

.btn-primary:active {
  background-color: #3a7bc8;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #999;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}
