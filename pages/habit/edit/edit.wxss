/* pages/habit/edit/edit.wxss */

.container {
  padding: 20rpx;
}

/* 表单区块 */
.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #4A90D9;
}

/* 图标选择 */
.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.icon-item {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.icon-item.selected {
  border-color: #4A90D9;
  background: #e6f4ff;
}

/* 颜色选择 */
.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.color-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.color-item.selected {
  border-color: #333;
  transform: scale(1.1);
}

/* 时间选择 */
.picker-input {
  height: 80rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 32rpx;
}

.picker-input .placeholder {
  color: #999;
}

.picker-arrow {
  color: #ccc;
  font-size: 36rpx;
}

/* 频率选择 */
.frequency-grid {
  display: flex;
  gap: 16rpx;
}

.frequency-item {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.frequency-item.selected {
  background: #4A90D9;
  color: #fff;
}

/* 按钮 */
.form-actions {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-danger {
  width: 100%;
  height: 96rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: 2rpx solid #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-danger::after {
  border: none;
}
