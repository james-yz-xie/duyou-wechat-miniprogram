/* pages/habit/edit/edit.wxss - 小清新风格，提高对比度 */

.container {
  padding: 24rpx;
  background: linear-gradient(180deg, #d8edd8 0%, #f0f7f0 20%);
}

/* 表单区块 */
.form-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(90, 171, 122, 0.1);
  border: 2rpx solid rgba(90, 171, 122, 0.15);
}

.form-label {
  font-size: 32rpx;
  color: #3a5a3a;
  margin-bottom: 22rpx;
  letter-spacing: 1rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 96rpx;
  font-size: 36rpx;
  border: 3rpx solid rgba(90, 171, 122, 0.25);
  border-radius: 18rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  background: rgba(90, 171, 122, 0.05);
  color: #2d4a2d;
}

.form-input:focus {
  border-color: #5aab7a;
  background: #fff;
}

/* 图标选择 */
.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.icon-item {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: rgba(90, 171, 122, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.icon-item.selected {
  border-color: #5aab7a;
  background: rgba(90, 171, 122, 0.2);
  box-shadow: 0 4rpx 14rpx rgba(90, 171, 122, 0.3);
}

/* 颜色选择 */
.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.color-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.color-item.selected {
  border-color: #2d4a2d;
  transform: scale(1.2);
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.18);
}

/* 时间选择 */
.picker-input {
  height: 96rpx;
  border: 3rpx solid rgba(90, 171, 122, 0.25);
  border-radius: 18rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 36rpx;
  background: rgba(90, 171, 122, 0.05);
  color: #2d4a2d;
}

.picker-input .placeholder {
  color: #7aa87a;
}

.picker-arrow {
  color: #8aa88a;
  font-size: 40rpx;
}

/* 频率选择 */
.frequency-grid {
  display: flex;
  gap: 18rpx;
}

.frequency-item {
  flex: 1;
  height: 88rpx;
  border-radius: 18rpx;
  background: rgba(90, 171, 122, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #4a7a4a;
  transition: all 0.2s;
  letter-spacing: 1rpx;
}

.frequency-item.selected {
  background: linear-gradient(135deg, #5aab7a 0%, #4a9a6a 100%);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(90, 171, 122, 0.35);
}

/* 按钮 */
.form-actions {
  margin-top: 56rpx;
  padding: 0 24rpx;
}

.btn-primary {
  width: 100%;
  height: 108rpx;
  background: linear-gradient(135deg, #5aab7a 0%, #4a9a6a 100%);
  color: #fff;
  font-size: 36rpx;
  border-radius: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  border: none;
  box-shadow: 0 10rpx 28rpx rgba(90, 171, 122, 0.4);
  letter-spacing: 2rpx;
}

.btn-primary::after {
  border: none;
}

.btn-danger {
  width: 100%;
  height: 108rpx;
  background: #fff;
  color: #d65a5a;
  font-size: 36rpx;
  border-radius: 54rpx;
  border: 3rpx solid rgba(214, 90, 90, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
}

.btn-danger::after {
  border: none;
}