/* pages/habit/habit.wxss - 小清新风格，提高对比度 */

.container {
  padding-bottom: 120rpx;
  background: linear-gradient(180deg, #d8edd8 0%, #f0f7f0 20%);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  padding: 28rpx;
  background: #fff;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(90, 171, 122, 0.1);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 32rpx;
  color: #4a7a4a;
  border-radius: 50rpx;
  transition: all 0.3s;
  letter-spacing: 1rpx;
}

.filter-item.active {
  background: linear-gradient(135deg, #5aab7a 0%, #4a9a6a 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(90, 171, 122, 0.35);
}

/* 习惯列表 */
.habit-list {
  padding: 0 24rpx;
}

.habit-card {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(90, 171, 122, 0.1);
  border: 2rpx solid rgba(90, 171, 122, 0.15);
}

.habit-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.habit-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  margin-right: 24rpx;
  background: rgba(90, 171, 122, 0.15);
}

.habit-info {
  flex: 1;
}

.habit-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #2d4a2d;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.habit-meta {
  font-size: 28rpx;
  color: #6a9a6a;
  letter-spacing: 0.5rpx;
}

.meta-divider {
  margin: 0 10rpx;
}

.habit-status {
  font-size: 26rpx;
  padding: 10rpx 22rpx;
  border-radius: 24rpx;
  letter-spacing: 1rpx;
}

.habit-status.active {
  background: rgba(90, 171, 122, 0.2);
  color: #4a8a4a;
}

.habit-status.archived {
  background: rgba(150, 150, 150, 0.2);
  color: #7a7a7a;
}

/* 进度条 */
.progress-bar {
  height: 14rpx;
  background: rgba(90, 171, 122, 0.2);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5aab7a 0%, #6abb8a 100%);
  border-radius: 10rpx;
  transition: width 0.3s;
}

.progress-label {
  font-size: 28rpx;
  color: #6a9a6a;
  text-align: center;
  letter-spacing: 1rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 36rpx;
  opacity: 0.55;
}

.empty-text {
  color: #6a9a6a;
  font-size: 32rpx;
  letter-spacing: 1rpx;
}

/* 浮动添加按钮 */
.float-add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 116rpx;
  height: 116rpx;
  background: linear-gradient(135deg, #5aab7a 0%, #4a9a6a 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 56rpx;
  box-shadow: 0 8rpx 32rpx rgba(90, 171, 122, 0.45);
}

.float-add-btn-hover {
  transform: scale(0.95);
}