/* pages/habit/habit.wxss */

.container {
  padding-bottom: 120rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  padding: 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 40rpx;
  transition: all 0.3s;
}

.filter-item.active {
  background: #4A90D9;
  color: #fff;
}

/* 习惯列表 */
.habit-list {
  padding: 0 20rpx;
}

.habit-card {
  margin-bottom: 20rpx;
}

.habit-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.habit-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.habit-info {
  flex: 1;
}

.habit-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.habit-meta {
  font-size: 24rpx;
  color: #999;
}

.meta-divider {
  margin: 0 8rpx;
}

.habit-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.habit-status.active {
  background: #e6f7ff;
  color: #1890ff;
}

.habit-status.archived {
  background: #f5f5f5;
  color: #999;
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-label {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* 浮动添加按钮 */
.float-add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.float-add-btn-hover {
  transform: scale(0.95);
}
