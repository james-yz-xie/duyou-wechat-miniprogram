/* pages/stats/stats.wxss - 小清新风格，提高对比度 */

.container {
  padding-bottom: 40rpx;
  background: linear-gradient(180deg, #d8edd8 0%, #f0f7f0 20%);
}

/* 总览卡片 */
.overview-card {
  background: linear-gradient(135deg, #5aab7a 0%, #6abb8a 50%, #7acc9a 100%);
  color: #fff;
  margin: 24rpx;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(90, 171, 122, 0.3);
}

.overview-title {
  font-size: 32rpx;
  margin-bottom: 28rpx;
  opacity: 0.98;
  letter-spacing: 1rpx;
}

.overview-stats {
  display: flex;
  justify-content: space-around;
}

.overview-item {
  text-align: center;
}

.overview-value {
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  letter-spacing: -1rpx;
}

.overview-label {
  font-size: 28rpx;
  opacity: 0.95;
  letter-spacing: 1rpx;
}

/* Section */
.section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3a5a3a;
  letter-spacing: 1rpx;
}

.section-sub {
  font-size: 28rpx;
  color: #6a9a6a;
}

/* 本周打卡 */
.week-grid {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(90, 171, 122, 0.1);
  border: 2rpx solid rgba(90, 171, 122, 0.15);
}

.week-day {
  flex: 1;
  text-align: center;
}

.day-label {
  font-size: 28rpx;
  color: #5a8a5a;
  margin-bottom: 14rpx;
}

.day-dots {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.day-dot {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  background: rgba(90, 171, 122, 0.2);
  transition: all 0.2s;
}

.day-dot.checked {
  background: linear-gradient(135deg, #5aab7a 0%, #4a9a6a 100%);
  transform: scale(1.2);
  box-shadow: 0 3rpx 10rpx rgba(90, 171, 122, 0.4);
}

/* 习惯统计 */
.habit-stats-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.habit-stat-card {
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(90, 171, 122, 0.1);
  border: 2rpx solid rgba(90, 171, 122, 0.15);
}

.stat-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.habit-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  background: rgba(90, 171, 122, 0.15);
}

.habit-name {
  font-size: 34rpx;
  font-weight: 500;
  color: #2d4a2d;
  letter-spacing: 1rpx;
}

.stat-grid {
  display: flex;
  margin-bottom: 24rpx;
}

.stat-grid-item {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  background: rgba(90, 171, 122, 0.08);
  border-radius: 18rpx;
  margin: 0 8rpx;
}

.stat-grid-item:first-child {
  margin-left: 0;
}

.stat-grid-item:last-child {
  margin-right: 0;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #5aab7a;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #5a8a5a;
  letter-spacing: 0.5rpx;
}

/* 热力图 */
.heatmap {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.heatmap-cell {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  background: rgba(90, 171, 122, 0.12);
}

.heatmap-cell.level-1 {
  background: rgba(90, 171, 122, 0.3);
}

.heatmap-cell.level-2 {
  background: rgba(90, 171, 122, 0.5);
}

.heatmap-cell.level-3 {
  background: rgba(90, 171, 122, 0.75);
}

.heatmap-cell.level-4 {
  background: #5aab7a;
  box-shadow: 0 3rpx 10rpx rgba(90, 171, 122, 0.4);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 3rpx dashed rgba(90, 171, 122, 0.4);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 28rpx;
  opacity: 0.55;
}

.empty-text {
  color: #6a9a6a;
  letter-spacing: 1rpx;
  font-size: 30rpx;
}