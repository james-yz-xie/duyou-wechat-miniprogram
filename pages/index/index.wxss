/* pages/index/index.wxss - 小清新风格，提高对比度 */

.container {
  padding-bottom: 120rpx;
  background: linear-gradient(180deg, #d8edd8 0%, #f0f7f0 20%);
}

/* 头部统计卡片 */
.header-card {
  background: linear-gradient(135deg, #5aab7a 0%, #6abb8a 50%, #7acc9a 100%);
  margin: 24rpx;
  color: #fff;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(90, 171, 122, 0.3);
}

.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 28rpx 0;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  letter-spacing: -1rpx;
}

.stat-label {
  font-size: 28rpx;
  opacity: 0.95;
  letter-spacing: 1rpx;
}

.stat-divider {
  width: 2rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.35);
}

/* Section */
.section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3a5a3a;
  letter-spacing: 1rpx;
}

.section-date {
  font-size: 28rpx;
  color: #6a9a6a;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 3rpx dashed rgba(90, 171, 122, 0.4);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 28rpx;
  opacity: 0.65;
}

.empty-text {
  color: #5a8a5a;
  margin-bottom: 36rpx;
  font-size: 32rpx;
}

.add-btn {
  display: inline-block;
  background: linear-gradient(135deg, #5aab7a 0%, #4a9a6a 100%);
  color: #fff;
  padding: 22rpx 56rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(90, 171, 122, 0.35);
  letter-spacing: 1rpx;
}

/* 习惯列表 */
.habit-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.habit-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  transition: all 0.3s;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(90, 171, 122, 0.1);
  border: 2rpx solid rgba(90, 171, 122, 0.15);
}

.habit-item.checked {
  background: linear-gradient(135deg, rgba(90, 171, 122, 0.12) 0%, rgba(106, 187, 138, 0.08) 100%);
  border-color: rgba(90, 171, 122, 0.4);
}

.habit-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.habit-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 28rpx;
  background: rgba(90, 171, 122, 0.15);
}

.habit-info {
  flex: 1;
}

.habit-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #2d4a2d;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.habit-streak {
  font-size: 28rpx;
}

.streak-badge {
  color: #e89a3c;
  font-weight: 600;
}

.streak-hint {
  color: #7aa87a;
}

.habit-right {
  margin-left: 28rpx;
}

.check-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(90, 171, 122, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: rgba(90, 171, 122, 0.35);
  transition: all 0.3s;
  background: #fff;
}

.check-btn.checked {
  background: linear-gradient(135deg, #5aab7a 0%, #4a9a6a 100%);
  border-color: #5aab7a;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(90, 171, 122, 0.4);
}

/* 浮动添加按钮 */
.float-add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 116rpx;
  height: 116rpx;
  background: linear-gradient(135deg, #5aab7a 0%, #4a9a6a 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 56rpx;
  box-shadow: 0 8rpx 32rpx rgba(90, 171, 122, 0.45);
}

.float-add-btn-hover {
  transform: scale(0.95);
}