/* pages/profile/profile.wxss */

.container {
  padding-bottom: 40rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx;
  margin: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.user-avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
}

.user-id {
  font-size: 20rpx;
  opacity: 0.7;
  margin-left: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 授权区域 */
.auth-section {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  margin-bottom: 10rpx;
}

.auth-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.auth-btn::after {
  border: none;
}

.demo-btn {
  flex: 1;
  height: 80rpx;
  background: #fff;
  color: #666;
  font-size: 28rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ddd;
}

.demo-btn::after {
  border: none;
}

/* Section */
.section {
  padding: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

/* 成就 */
.achievement-grid {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.achievement-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
}

.achievement-item:last-child {
  border-right: none;
}

.achievement-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90D9;
  margin-bottom: 8rpx;
}

.achievement-label {
  font-size: 24rpx;
  color: #999;
}

/* 菜单 */
.menu-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background: #f8f8f8;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-size: 36rpx;
}

/* 版本 */
.version-info {
  text-align: center;
  padding: 40rpx;
  color: #ccc;
  font-size: 24rpx;
}
