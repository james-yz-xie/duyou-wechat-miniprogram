/* pages/profile/profile.wxss - 小清新风格，提高对比度 */

.container {
  padding-bottom: 40rpx;
  background: linear-gradient(180deg, #d8edd8 0%, #f0f7f0 20%);
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 48rpx;
  margin: 24rpx;
  background: linear-gradient(135deg, #5aab7a 0%, #6abb8a 50%, #7acc9a 100%);
  color: #fff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(90, 171, 122, 0.3);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 28rpx;
}

.user-avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 28rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.7);
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.user-id {
  font-size: 26rpx;
  opacity: 0.95;
  margin-left: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
}

.user-desc {
  font-size: 30rpx;
  opacity: 0.95;
  letter-spacing: 1rpx;
}

/* 授权区域 */
.auth-section {
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.auth-btn {
  width: calc(100% - 48rpx);
  height: 96rpx;
  background: linear-gradient(135deg, #5aab7a 0%, #4a9a6a 100%);
  color: #fff;
  font-size: 34rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(90, 171, 122, 0.4);
  letter-spacing: 2rpx;
}

.auth-btn::after {
  border: none;
}

/* Section */
.section {
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  color: #3a5a3a;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 成就 */
.achievement-grid {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(90, 171, 122, 0.12);
  border: 2rpx solid rgba(90, 171, 122, 0.18);
}

.achievement-item {
  flex: 1;
  text-align: center;
  border-right: 2rpx solid rgba(90, 171, 122, 0.18);
}

.achievement-item:last-child {
  border-right: none;
}

.achievement-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #5aab7a;
  margin-bottom: 10rpx;
  letter-spacing: -1rpx;
}

.achievement-label {
  font-size: 28rpx;
  color: #5a7a5a;
  letter-spacing: 1rpx;
}

/* 菜单 */
.menu-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(90, 171, 122, 0.1);
  border: 2rpx solid rgba(90, 171, 122, 0.15);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx;
  border-bottom: 2rpx solid rgba(90, 171, 122, 0.1);
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background: rgba(90, 171, 122, 0.08);
}

.menu-icon {
  font-size: 44rpx;
  margin-right: 28rpx;
}

.menu-text {
  flex: 1;
  font-size: 34rpx;
  color: #2d4a2d;
  letter-spacing: 1rpx;
}

.menu-arrow {
  color: #8aa88a;
  font-size: 40rpx;
}

/* 危险操作按钮 */
.menu-item-danger .menu-text {
  color: #d65a5a;
}

/* 版本 */
.version-info {
  text-align: center;
  padding: 48rpx;
  color: #8aa88a;
  font-size: 28rpx;
  letter-spacing: 2rpx;
}